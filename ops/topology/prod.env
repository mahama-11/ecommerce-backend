# Non-secret production topology contract for Agent Ecommerce deploy/smoke automation.
# Scripts source this file. Keep secrets in remote host config only.

ENV_NAME=prod
REMOTE_DEFAULT=root@159.138.228.40
REMOTE_DIR_DEFAULT=/root/gk/ecommerce-backend
REMOTE_BASE_DEFAULT=/root/gk
SSH_KEY_DEFAULT=$HOME/.ssh/KeyPair-v2.pem
DOCKER_NETWORK=shared-network
DB_CONTAINER=kong-database
DB_USER=kong
DB_NAME=kong

ECOMMERCE_CONTAINER=v-ecommerce-backend
ECOMMERCE_IMAGE=ver/v-ecommerce-backend
ECOMMERCE_SERVICE=prod-backend
ECOMMERCE_HOST_PORT=8296
ECOMMERCE_INTERNAL_URL=http://v-ecommerce-backend:8296
ECOMMERCE_LOCAL_URL=http://127.0.0.1:8296
ECOMMERCE_HEALTH_URL=http://127.0.0.1:8296/healthz
ECOMMERCE_READY_URL=http://127.0.0.1:8296/readyz
ECOMMERCE_CONFIG_PATH=/root/gk/ecommerce-backend/config.prod.yaml

PLATFORM_CONTAINER=v-platform-backend
PLATFORM_REMOTE_DIR=/root/gk/platform-backend
PLATFORM_HOST_PORT=8095
PLATFORM_INTERNAL_URL=http://v-platform-backend:8095
PLATFORM_LOCAL_URL=http://127.0.0.1:8095
PLATFORM_CONFIG_PATH=/root/gk/platform-backend/config.prod.yaml
PLATFORM_RUNTIME_QUEUE_NAME=runtime:prod

DEV_ECOMMERCE_CONTAINER=v-ecommerce-backend-dev
DEV_ECOMMERCE_HOST_PORT=8396
DEV_PLATFORM_CONTAINER=v-platform-backend-dev
DEV_PLATFORM_HOST_PORT=8195

EXPECTED_TEXT_PROVIDER=kimi_coding_text
EXPECTED_TEXT_TASKS="text_reasoning intent_planning prompt_planning strategy_report"
ECOMMERCE_REQUIRED_TABLES="ecom_product_sku ecommerce_assets ecommerce_image_jobs ecommerce_visual_workflow_sessions ecommerce_visual_source_references ecommerce_visual_deconstruction_jobs ecommerce_visual_deconstruction_elements"
